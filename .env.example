# Public site URL (optional; used for metadata, sitemap, OG — set in Vercel)
NEXT_PUBLIC_SITE_URL=https://offermatch.io

# Supabase (Project Settings → API)
SUPABASE_URL=https://your-project.supabase.co
# Service role key — server-only; never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# Admin UI at /admin — generate a long random string
ADMIN_SECRET=

# Slack incoming webhook (server-only) — notify on each completed partner signup
SLACK_WEBHOOK_URL=
